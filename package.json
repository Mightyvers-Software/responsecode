{
  "name": "project",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "copy:docs": "cp -R docs dist",
    "docs": "node docs.js && npm run copy:docs",
    "clean": "rm -rf dist",
    "serve": "live-server dist",
    "scss": "sass src/scss/main.scss dist/css/main.css",
    "scss:watch": "sass --watch src/scss/main.scss:dist/css/main.css",
    "copy:assets": "cp -R src/assets dist",
    "html:watch": "chokidar \"src/templates/**/*.njk\" -c \"node build.js\"",
    "build:html": "node build.js",
    "build:css": "sass src/scss/main.scss dist/css/main.css --style=compressed",
    "build": "npm run build:html && npm run build:css && npm run copy:assets",
    "build:prod": "NODE_ENV=production npm run build:css && npm run copy:assets && NODE_ENV=production npm run build:html",
    "deploy":"NODE_ENV=production npm run build:css && npm run copy:assets && NODE_ENV=production npm run build:html && npm run docs",
    "dev": "npm run build && npm-run-all --parallel scss:watch html:watch serve"
  },
  "author": "MightyVers Software",
  "license": "MIT",
  "description": "",
  "engineStrict": true,
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.3",
    "html-include-element": "^0.3.0",
    "html-minifier-terser": "^7.2.0",
    "live-server": "^1.2.2",
    "marked": "^18.0.5",
    "npm-run-all": "^4.1.5",
    "nunjucks": "^3.2.4",
    "sass": "^1.100.0"
  }
}
