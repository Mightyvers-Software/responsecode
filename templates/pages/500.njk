{% extends "../layouts/base.njk" %}

{% set code = "500" %}
{% set title = "Internal Server Error" %}
{% set message = "Something went wrong on our side." %}

{% block content %}
<section class="error-card">

    <span class="error-code">
        {{ code }}
    </span>

    <h1>
        {{ title }}
    </h1>

    <p>
        {{ message }}
    </p>

</section>
{% endblock %}